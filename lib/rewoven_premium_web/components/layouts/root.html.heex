<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <title>{assigns[:page_title] || "Rewoven Premium"}</title>
    <meta name="description" content="Unlock the Rewoven Curriculum, unlimited fabric scans, and the multiplayer quiz for $4.99/month." />
    <link rel="icon" href="https://rewovenapp.com/assets/logo.png" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet" />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}></script>
  </head>
  <body
    data-supabase-url={Application.get_env(:rewoven_premium, :supabase_url)}
    data-supabase-anon-key={Application.get_env(:rewoven_premium, :supabase_anon_key)}
  >
    {@inner_content}
  </body>
</html>
